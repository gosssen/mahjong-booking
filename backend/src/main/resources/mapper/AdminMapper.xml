<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.mahjong.mapper.AdminMapper">

  <resultMap id="adminMap" type="com.mahjong.model.Admin">
    <id     property="id"          column="id"/>
    <result property="lineUserId"  column="line_user_id"/>
    <result property="displayName" column="display_name"/>
    <result property="addedBy"     column="added_by"/>
    <result property="createdAt"   column="created_at"/>
  </resultMap>

  <select id="existsByLineUserId" resultType="boolean">
    SELECT COUNT(*) > 0 FROM admins WHERE line_user_id = #{lineUserId}
  </select>

  <select id="count" resultType="long">
    SELECT COUNT(*) FROM admins
  </select>

  <select id="findAll" resultMap="adminMap">
    SELECT a.*, u.display_name
    FROM admins a
    LEFT JOIN users u ON u.line_user_id = a.line_user_id
    ORDER BY a.created_at
  </select>

  <insert id="insert" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO admins (line_user_id, added_by)
    VALUES (#{lineUserId}, #{addedBy})
  </insert>

  <delete id="deleteByLineUserId">
    DELETE FROM admins WHERE line_user_id = #{lineUserId}
  </delete>

  <delete id="deleteById">
    DELETE FROM admins WHERE id = #{id}
  </delete>

</mapper>
